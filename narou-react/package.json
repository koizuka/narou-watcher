{
  "name": "narou-react",
  "version": "0.1.0",
  "homepage": "./",
  "private": true,
  "type": "module",
  "engines": {
    "yarn": "please-use-npm"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "date-fns": "^4.1.0",
    "globals": "^17.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "scroll-into-view-if-needed": "^3.1.0",
    "swr": "^2.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "lint": "eslint -c eslint.config.mts src/**/*.{ts,tsx}",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:visual": "cross-env BROWSER_TEST=true vitest",
    "test:visual:ci": "cross-env BROWSER_TEST=true vitest run",
    "test:visual:update": "cross-env BROWSER_TEST=true vitest run --update"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.7.3",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.0.3",
    "@vitest/eslint-plugin": "^1.6.16",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "jest-environment-jsdom": "^30.3.0",
    "jiti": "^2.7.0",
    "playwright": "^1.59.1",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.3",
    "vitest-browser-react": "^2.2.0",
    "whatwg-fetch": "^3.6.20"
  }
}
